# === Anthropic API ===
# Used by Cognee (entity extraction) and Explorer (research agent)
# NOTE: Do NOT prefix LLM_MODEL with "anthropic/" — Cognee's LiteLLM adds the prefix internally.
ANTHROPIC_API_KEY=your_anthropic_api_key
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514
LLM_API_KEY=your_anthropic_api_key

# === Embedding (Ollama, runs in Docker) ===
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=qwen3-embedding:4b
EMBEDDING_ENDPOINT=http://ollama:11434/api/embed
EMBEDDING_DIMENSIONS=2560
HUGGINGFACE_TOKENIZER=Qwen/Qwen3-Embedding-4B

# === Cognee auth ===
COGNEE_USER=admin@secondmind.local
COGNEE_PASS=second-mind-local
COGNEE_API_TOKEN=second-mind-local

# === Neo4j (graph database) ===
NEO4J_PASSWORD=secondmind

# === Postgres (vectors, cache, metadata) ===
POSTGRES_USER=cognee
POSTGRES_PASSWORD=cognee
POSTGRES_DB=cognee

# === Explorer ===
EXPLORER_MODEL=claude-sonnet-4-20250514
# EXPLORER_RESEARCH_MODEL=claude-haiku-4-5-20251001
# EXPLORER_MAX_COST_CENTS=100

# === Graph engine ===
# Max gleaning passes per chunk during extraction (default: 1)
# MAX_GLEANINGS=1

# === Intake engine ===
# EMBEDDING_MAX_TOKENS=32000
# COGNEE_CHUNKS_PER_BATCH=5
